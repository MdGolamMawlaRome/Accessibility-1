<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fullscreenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">

    <LinearLayout
        android:id="@+id/popupRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/popup_background"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/mainControlsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/imgBrightness"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_brightness"
                    android:layout_marginEnd="8dp"/>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1">
                    <SeekBar
                        android:id="@+id/brightnessSlider"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:max="100"
                        android:progressDrawable="@drawable/custom_slider_bar"
                        android:thumb="@null"
                        android:splitTrack="false" />
                    <TextView
                        android:id="@+id/brightnessPercentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:text="50%"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <ImageView
                    android:id="@+id/imgMainVolume"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_volume_media"
                    android:layout_marginEnd="8dp"/>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1">
                    <SeekBar
                        android:id="@+id/mainVolumeSlider"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:max="100"
                        android:progressDrawable="@drawable/custom_slider_bar"
                        android:thumb="@null"
                        android:splitTrack="false" />
                    <TextView
                        android:id="@+id/mainVolumePercentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:text="50%"/>
                </FrameLayout>
                <ImageView
                    android:id="@+id/btnExpand"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_more_vert"
                    android:layout_marginStart="8dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">
                <LinearLayout
                    android:id="@+id/btnScreenshot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/imgScreenshot"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_screenshot"/>
                    <TextView
                        android:id="@+id/btnScreenshotText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Capture"
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/btnPower"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/imgPower"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_power"/>
                    <TextView
                        android:id="@+id/btnPowerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Power"
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/btnLock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/imgLock"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_lock"/>
                    <TextView
                        android:id="@+id/btnLockText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock"
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/expandedVolumeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:id="@+id/btnVolumeBack"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volume Controls"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <include layout="@layout/row_volume_slider" android:id="@+id/rowMedia"/>
            <include layout="@layout/row_volume_slider" android:id="@+id/rowRing"/>
            <include layout="@layout/row_volume_slider" android:id="@+id/rowNotification"/>
            <include layout="@layout/row_volume_slider" android:id="@+id/rowSystem"/>
            <include layout="@layout/row_volume_slider" android:id="@+id/rowCall"/>
            <include layout="@layout/row_volume_slider" android:id="@+id/rowAlarm"/>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
